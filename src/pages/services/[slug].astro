---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { clinic } from '@/data/clinic';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map(s => ({ params:{ slug:s.data.slug }, props:{ service:s } }));
}

const { service } = Astro.props;
const { data: d }  = service;

const icons: Record<string,string> = {
  stethoscope:    `<path stroke-linecap="round" stroke-linejoin="round" d="M9 3H7a2 2 0 00-2 2v11a4 4 0 004 4h6a4 4 0 004-4V5a2 2 0 00-2-2h-2M9 3a2 2 0 002 2h2a2 2 0 002-2M9 3a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3"/>`,
  'heart-pulse':  `<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>`,
  bandage:        `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
  droplets:       `<path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>`,
  plane:          `<path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>`,
  scissors:       `<path stroke-linecap="round" stroke-linejoin="round" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z"/>`,
  'flask-conical':`<path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>`,
  'clipboard-list':`<path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3"/>`,
  smile:          `<path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  activity:       `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12" stroke-linecap="round" stroke-linejoin="round"/>`,
};

const schemas = [
  { "@context":"https://schema.org","@type":"MedicalProcedure","name":d.name,"description":d.shortDescription,"provider":{"@type":"MedicalClinic","@id":`${clinic.url}/#clinic`} },
  { "@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[
    {"@type":"ListItem","position":1,"name":"Home","item":clinic.url+"/"},
    {"@type":"ListItem","position":2,"name":"Services","item":clinic.url+"/services"},
    {"@type":"ListItem","position":3,"name":d.name,"item":`${clinic.url}/services/${d.slug}`}
  ]}
];
---

<BaseLayout
  title={`${d.name} – Legian Medical Clinic Bali`}
  description={d.shortDescription}
  schemaMarkup={schemas}
>
  <!-- Header -->
  <section class="border-b border-border bg-surface py-12 page-hero">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-5">
        <ol class="flex items-center gap-2 text-xs text-ink-secondary/60">
          <li><a href="/" class="hover:text-ink transition-colors">Home</a></li>
          <li aria-hidden="true">·</li>
          <li><a href="/services" class="hover:text-ink transition-colors">Services</a></li>
          <li aria-hidden="true">·</li>
          <li><span class="text-ink" aria-current="page">{d.name}</span></li>
        </ol>
      </nav>
      <div class="flex items-start gap-4">
        <div class="w-11 h-11 bg-primary-light rounded-xl flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75" set:html={icons[d.icon]??icons.stethoscope}/>
        </div>
        <div>
          {d.isEmergency && <span class="badge-emergency mb-2 block w-fit">Emergency Service</span>}
          <h1 class="font-heading font-bold text-3xl md:text-4xl text-ink leading-tight">{d.name}</h1>
          <p class="text-ink-secondary mt-1 max-w-xl">{d.shortDescription}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main -->
        <div class="lg:col-span-2 appear">
          <h2 class="font-heading font-semibold text-ink text-xl mb-3">About This Service</h2>
          <p class="text-ink-secondary leading-relaxed text-[0.9375rem] mb-8">{d.fullDescription}</p>

          <h3 class="font-heading font-semibold text-ink mb-4">What's Included</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2.5">
            {d.features.map(f => (
              <div class="flex items-start gap-3 border border-border rounded-lg p-3.5">
                <svg class="w-4 h-4 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-sm text-ink">{f}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-5 appear">
          <!-- Clinic info -->
          <div class="border border-border rounded-xl overflow-hidden">
            <div class="px-4 py-3 bg-surface border-b border-border">
              <p class="section-label">Clinic Info</p>
            </div>
            <div class="divide-y divide-border">
              <div class="px-4 py-3 flex gap-3">
                <svg class="w-4 h-4 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <div>
                  <p class="text-label text-ink-secondary/60 mb-0.5">Hours</p>
                  <p class="text-sm text-ink">{clinic.hours.display}</p>
                </div>
              </div>
              <div class="px-4 py-3 flex gap-3">
                <svg class="w-4 h-4 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <div>
                  <p class="text-label text-ink-secondary/60 mb-0.5">Location</p>
                  <p class="text-sm text-ink">{clinic.address.street}, {clinic.address.locality}</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Contact -->
          <div class="border border-border rounded-xl overflow-hidden">
            <div class="px-4 py-3 bg-surface border-b border-border">
              <p class="section-label">Get This Service</p>
            </div>
            <div class="p-4 space-y-2.5">
              <a href={`https://wa.me/${clinic.contact.whatsapp}`} target="_blank" rel="noopener noreferrer" class="btn-whatsapp w-full justify-center">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a6.18 6.18 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.128.558 4.127 1.535 5.857L.057 23.882a.5.5 0 00.612.612l6.055-1.476A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.016-1.375l-.359-.214-3.728.908.936-3.628-.234-.374A9.818 9.818 0 1112 21.818z"/></svg>
                Chat on WhatsApp
              </a>
              <a href={`tel:${clinic.contact.phone}`} class="btn-outline w-full justify-center">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                Call Us
              </a>
            </div>
          </div>

          <a href="/services" class="inline-flex items-center gap-1.5 text-ink-secondary text-sm hover:text-primary transition-colors">
            <svg class="w-3.5 h-3.5 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            All Services
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
