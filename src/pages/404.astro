---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found – Legian Medical Clinic" description="The page you are looking for could not be found.">
  <section class="min-h-[70vh] flex items-center justify-center bg-white">
    <div class="max-w-sm mx-auto px-4 text-center">
      <p class="font-heading font-bold text-8xl text-border mb-2">404</p>
      <h1 class="font-heading font-bold text-2xl text-ink mb-3">Page Not Found</h1>
      <p class="text-ink-secondary text-sm mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="btn-primary btn-lg">Go to Homepage</a>
        <a href="/contact" class="btn-outline btn-lg">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
