---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { clinic } from '@/data/clinic';

const all     = await getCollection('doctors');
const doctors = all.sort((a,b)=>a.data.order-b.data.order);

const physSchema = doctors.map(d => ({
  "@context":"https://schema.org","@type":"Physician",
  "name":d.data.name,"medicalSpecialty":d.data.specialization,
  "worksFor":{"@type":"MedicalClinic","@id":`${clinic.url}/#clinic`},
  "knowsLanguage":d.data.languages.map(l=>l==='Indonesian'?'id':'en'),
}));
const breadcrumb = {
  "@context":"https://schema.org","@type":"BreadcrumbList",
  "itemListElement":[
    {"@type":"ListItem","position":1,"name":"Home","item":clinic.url+"/"},
    {"@type":"ListItem","position":2,"name":"Doctors","item":clinic.url+"/doctors"}
  ]
};
---

<BaseLayout
  title="Our Doctors – Legian Medical Clinic"
  description="Meet our qualified medical team at Legian Medical Clinic, Bali. Experienced doctors speaking English and Indonesian, available daily."
  schemaMarkup={[...physSchema, breadcrumb]}
>
  <!-- Header -->
  <section class="border-b border-border bg-surface py-12 page-hero">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-5">
        <ol class="flex items-center gap-2 text-xs text-ink-secondary/60">
          <li><a href="/" class="hover:text-ink transition-colors">Home</a></li>
          <li aria-hidden="true">·</li>
          <li><span class="text-ink" aria-current="page">Doctors</span></li>
        </ol>
      </nav>
      <p class="section-label mb-2">Medical Team</p>
      <h1 class="font-heading font-bold text-3xl md:text-4xl text-ink">Our Doctors</h1>
      <p class="text-ink-secondary mt-2 max-w-xl">Qualified, compassionate, and fluent in English — our doctors are here for you.</p>
    </div>
  </section>

  <!-- Grid -->
  <section class="py-20 bg-white" aria-label="Doctor profiles">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 appear-group">
        {doctors.map(doc => (
          <article class="card appear" data-anim="scale-up">
            <!-- Photo -->
            <div class="bg-surface aspect-[4/3] flex items-center justify-center border-b border-border">
              <div class="w-24 h-24 bg-primary-mid rounded-full flex items-center justify-center">
                <svg class="w-12 h-12 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
            </div>
            <div class="p-5">
              <p class="section-label mb-1">{doc.data.specialization}</p>
              <h2 class="font-heading font-semibold text-ink text-lg leading-tight">{doc.data.name}</h2>
              <p class="text-ink-secondary text-sm mb-4">{doc.data.title}</p>

              <!-- Education -->
              {doc.data.education.length > 0 && (
                <div class="mb-4 space-y-1">
                  {doc.data.education.map(edu => (
                    <p class="text-xs text-ink-secondary flex items-start gap-2">
                      <svg class="w-3.5 h-3.5 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
                      {edu}
                    </p>
                  ))}
                </div>
              )}

              <!-- Schedule -->
              {doc.data.schedule && (
                <div class="flex items-center gap-2 text-xs text-ink-secondary mb-3">
                  <svg class="w-3.5 h-3.5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                  {doc.data.schedule}
                </div>
              )}

              <!-- Languages -->
              <div class="flex flex-wrap gap-1.5">
                {doc.data.languages.map(l=><span class="badge-blue">{l}</span>)}
              </div>

              {doc.data.bio && (
                <p class="text-ink-secondary text-xs leading-relaxed mt-4 pt-4 border-t border-border">{doc.data.bio}</p>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Questions CTA -->
  <section class="py-14 border-t border-border bg-surface" aria-label="Contact prompt">
    <div class="max-w-lg mx-auto px-4 sm:px-6 text-center appear">
      <h2 class="section-title mb-3">Questions About Our Team?</h2>
      <p class="text-ink-secondary text-sm mb-7">Contact us to find out which doctor is on duty or to ask about specific services.</p>
      <a href="/contact" class="btn-primary btn-lg">Get in Touch</a>
    </div>
  </section>

</BaseLayout>
