---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { clinic } from '@/data/clinic';

const allServices  = await getCollection('services');
const featuredSvcs = allServices.filter(s => s.data.isFeatured).sort((a,b)=>a.data.order-b.data.order).slice(0,4);
const allDoctors   = await getCollection('doctors');
const previewDocs  = allDoctors.sort((a,b)=>a.data.order-b.data.order).slice(0,3);

/* ── Icon map ── */
const icons: Record<string,string> = {
  stethoscope:    `<path stroke-linecap="round" stroke-linejoin="round" d="M9 3H7a2 2 0 00-2 2v11a4 4 0 004 4h6a4 4 0 004-4V5a2 2 0 00-2-2h-2M9 3a2 2 0 002 2h2a2 2 0 002-2M9 3a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3"/>`,
  'heart-pulse':  `<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>`,
  bandage:        `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
  droplets:       `<path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>`,
};

const faqSchema = {
  "@context":"https://schema.org","@type":"FAQPage",
  "mainEntity":[
    {"@type":"Question","name":"Is Legian Medical Clinic open every day?","acceptedAnswer":{"@type":"Answer","text":"Yes, open every day including weekends and public holidays, 08:00–22:00 WIB."}},
    {"@type":"Question","name":"Do the doctors speak English?","acceptedAnswer":{"@type":"Answer","text":"Yes, all medical staff are fluent in English and Indonesian."}},
    {"@type":"Question","name":"Where is Legian Medical Clinic?","acceptedAnswer":{"@type":"Answer","text":`${clinic.address.full}. Accessible from Legian Beach, Kuta, and Seminyak.`}},
    {"@type":"Question","name":"What services does Legian Medical Clinic offer?","acceptedAnswer":{"@type":"Answer","text":"General practice, emergency care, IV drip therapy, wound treatment, travel medicine, vaccinations, lab tests, medical check-ups, dental care, and physiotherapy."}}
  ]
};
---

<BaseLayout
  title="Legian Medical Clinic – Medical Care in Legian Bali"
  description="Trusted clinic in Legian, Bali offering general practice, emergency care, IV drip, wound treatment & travel medicine. English-speaking doctors. Open daily 08:00–22:00."
  schemaMarkup={faqSchema}
>

  <!-- ── HERO ────────────────────────────────────────────── -->
  <section
    class="relative overflow-hidden bg-cover bg-center bg-no-repeat"
    style="background-image: url('/hero.webp');"
    aria-labelledby="hero-heading"
  >
    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/50 to-black/20 pointer-events-none" aria-hidden="true"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 lg:py-32">
      <div class="max-w-3xl">
        <!-- Status pill -->
        <div class="inline-flex items-center gap-2 border border-white/30 bg-white/10 backdrop-blur-sm text-white/90 text-xs font-body px-3.5 py-1.5 rounded-full mb-7">
          <span class="w-1.5 h-1.5 rounded-full bg-accent inline-block"></span>
          Open daily · English-speaking doctors
        </div>

        <h1 id="hero-heading" class="font-heading font-extrabold text-4xl sm:text-5xl md:text-6xl text-white leading-[1.1] tracking-tight mb-5">
          Trusted Medical Care<br/>
          <span class="text-primary">in Legian, Bali</span>
        </h1>

        <p class="text-white/80 text-lg md:text-xl leading-relaxed mb-8 max-w-xl">
          Professional healthcare for tourists, expats, and local residents — from emergency treatment to routine check-ups. Open every day, 08:00–22:00.
        </p>

        <div class="flex flex-wrap gap-3">
          <a href="/services" class="btn-primary btn-lg">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            Our Services
          </a>
          <a href={`https://wa.me/${clinic.contact.whatsapp}`} target="_blank" rel="noopener noreferrer" class="btn-whatsapp btn-lg">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a6.18 6.18 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.128.558 4.127 1.535 5.857L.057 23.882a.5.5 0 00.612.612l6.055-1.476A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.016-1.375l-.359-.214-3.728.908.936-3.628-.234-.374A9.818 9.818 0 1112 21.818z"/>
            </svg>
            WhatsApp Us
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 rounded-lg border border-white/40 bg-white/10 backdrop-blur-sm text-white text-sm font-medium px-5 py-2.5 hover:bg-white/20 transition-colors duration-200 btn-lg">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Find Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── INFO BAR ─────────────────────────────────────────── -->
  <section class="border-y border-border bg-surface" aria-label="Clinic quick info">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-border">
        {[
          { label:'Hours',     value:clinic.hours.opens + ' – ' + clinic.hours.closes, icon:`<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>` },
          { label:'WhatsApp',  value:clinic.contact.whatsappDisplay, icon:`<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a6.18 6.18 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.128.558 4.127 1.535 5.857L.057 23.882a.5.5 0 00.612.612l6.055-1.476A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.016-1.375l-.359-.214-3.728.908.936-3.628-.234-.374A9.818 9.818 0 1112 21.818z"/>`, fill:true },
          { label:'Location',  value:'Legian, Bali', icon:`<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>` },
          { label:'Languages', value:'English & Indonesian', icon:`<path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>` },
        ].map(item => (
          <div class="flex items-center gap-3 px-4 md:px-6 py-4">
            <div class="w-8 h-8 bg-primary-light rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-primary" fill={item.fill ? 'currentColor' : 'none'} stroke={item.fill ? 'none' : 'currentColor'} viewBox="0 0 24 24" aria-hidden="true" stroke-width={item.fill ? undefined : '1.75'} set:html={item.icon}/>
            </div>
            <div class="min-w-0">
              <p class="text-label text-ink-secondary/60 mb-0.5">{item.label}</p>
              <p class="text-sm font-medium text-ink truncate">{item.value}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FEATURED SERVICES ─────────────────────────────────── -->
  <section class="py-20 bg-white" aria-labelledby="services-h">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10 appear">
        <div>
          <p class="section-label mb-2">Featured Services</p>
          <h2 id="services-h" class="section-title">Comprehensive Medical Care</h2>
        </div>
        <a href="/services" class="btn-outline shrink-0">
          View all services
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 appear-group">
        {featuredSvcs.map(s => (
          <a href={`/services/${s.data.slug}`} class="card p-5 group appear hover:-translate-y-0.5 transition-transform duration-200">
            <div class="w-10 h-10 bg-primary-light rounded-lg flex items-center justify-center mb-4 group-hover:bg-primary transition-colors duration-200">
              <svg class="w-5 h-5 text-primary group-hover:text-white transition-colors duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75" set:html={icons[s.data.icon] ?? icons.stethoscope}/>
            </div>
            {s.data.isEmergency && <span class="badge-emergency mb-3">Emergency</span>}
            <h3 class="font-heading font-semibold text-ink text-base mb-1.5 group-hover:text-primary transition-colors">{s.data.name}</h3>
            <p class="text-ink-secondary text-sm leading-relaxed line-clamp-3">{s.data.shortDescription}</p>
            <div class="mt-4 flex items-center gap-1 text-primary text-sm font-medium">
              Learn more
              <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── WHY CHOOSE US ─────────────────────────────────────── -->
  <section class="py-20 bg-surface border-y border-border" aria-labelledby="why-h">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 appear">
        <p class="section-label mb-2">Why Choose Us</p>
        <h2 id="why-h" class="section-title">The Standard You Deserve</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 appear-group">
        {[
          { icon:`<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`, title:'Experienced Doctors', desc:'Licensed physicians with years of experience treating patients from across the world.' },
          { icon:`<path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>`, title:'English-Speaking', desc:'Our entire medical team communicates fluently in English and Indonesian.' },
          { icon:`<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>`, title:'Modern Facilities', desc:'Up-to-date equipment, clean treatment rooms, and an in-house laboratory.' },
          { icon:`<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>`, title:'Open Every Day', desc:'Including weekends and public holidays from 08:00 to 22:00 WIB.' },
        ].map(item => (
          <div class="appear">
            <div class="w-10 h-10 bg-primary-light rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75" set:html={item.icon}/>
            </div>
            <h3 class="font-heading font-semibold text-ink mb-2">{item.title}</h3>
            <p class="text-sm text-ink-secondary leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── DOCTORS PREVIEW ──────────────────────────────────── -->
  <section class="py-20 bg-white" aria-labelledby="doctors-h">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10 appear">
        <div>
          <p class="section-label mb-2">Medical Team</p>
          <h2 id="doctors-h" class="section-title">Meet Our Doctors</h2>
        </div>
        <a href="/doctors" class="btn-outline shrink-0">
          See all doctors
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 appear-group">
        {previewDocs.map(doc => (
          <div class="card appear">
            <div class="bg-surface aspect-[5/3] flex items-center justify-center border-b border-border">
              <div class="w-20 h-20 bg-primary-mid rounded-full flex items-center justify-center">
                <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.25">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
            </div>
            <div class="p-5">
              <p class="section-label mb-1">{doc.data.specialization}</p>
              <h3 class="font-heading font-semibold text-ink text-lg">{doc.data.name}</h3>
              <p class="text-ink-secondary text-sm mb-3">{doc.data.title}</p>
              {doc.data.schedule && (
                <div class="flex items-center gap-2 text-ink-secondary text-xs mb-3">
                  <svg class="w-3.5 h-3.5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                  {doc.data.schedule}
                </div>
              )}
              <div class="flex flex-wrap gap-1.5">
                {doc.data.languages.map(l => <span class="badge-blue">{l}</span>)}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────────────── -->
  <section class="py-16 border-y border-border bg-surface" aria-labelledby="cta-h">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center appear">
      <p class="section-label mb-3">Need Help?</p>
      <h2 id="cta-h" class="section-title mb-4">Need Medical Assistance in Bali?</h2>
      <p class="text-ink-secondary mb-8">
        Walk in anytime or reach us on WhatsApp. Our doctors are available every day, 08:00–22:00 WIB.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href={`https://wa.me/${clinic.contact.whatsapp}`} target="_blank" rel="noopener noreferrer" class="btn-whatsapp btn-lg">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a6.18 6.18 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.128.558 4.127 1.535 5.857L.057 23.882a.5.5 0 00.612.612l6.055-1.476A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.016-1.375l-.359-.214-3.728.908.936-3.628-.234-.374A9.818 9.818 0 1112 21.818z"/>
          </svg>
          Chat on WhatsApp
        </a>
        <a href={`tel:${clinic.contact.phone}`} class="btn-outline btn-lg">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          {clinic.contact.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- ── FAQ ──────────────────────────────────────────────── -->
  <section class="py-20 bg-white" aria-labelledby="faq-h">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10 appear">
        <p class="section-label mb-2">FAQ</p>
        <h2 id="faq-h" class="section-title">Frequently Asked Questions</h2>
      </div>
      <div class="space-y-2 appear">
        {[
          { q:'Is Legian Medical Clinic open every day?',          a:'Yes, we are open every day including weekends and public holidays, from 08:00 to 22:00 WIB.' },
          { q:'Do the doctors speak English?',                      a:'Yes, all of our medical staff are fluent in English and Indonesian.' },
          { q:'Where is Legian Medical Clinic located?',            a:`${clinic.address.full}. Easily reachable from Legian Beach, Kuta, and Seminyak.` },
          { q:'What services does Legian Medical Clinic offer?',    a:'General practice, emergency care, IV drip therapy, wound treatment, travel medicine & vaccinations, minor surgery, laboratory tests, medical check-ups, dental care, and physiotherapy.' },
          { q:'Do you accept credit cards and insurance?',          a:`We accept cash (IDR and USD) and credit/debit cards. Contact us in advance to confirm insurance coverage.` },
        ].map(item => (
          <details class="group border border-border rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer font-body font-medium text-ink text-sm list-none hover:bg-surface transition-colors select-none">
              {item.q}
              <svg class="w-4 h-4 text-ink-secondary shrink-0 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-5 pb-4 pt-0 text-sm text-ink-secondary leading-relaxed border-t border-border">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
