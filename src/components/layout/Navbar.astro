---
import { clinic } from '@/data/clinic';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
const logoSvg = readFileSync(resolve(process.cwd(), 'public/lmc.svg'), 'utf-8');

const navLinks = [
  { href: '/',         label: 'Home'     },
  { href: '/about',    label: 'About'    },
  { href: '/services', label: 'Services' },
  { href: '/doctors',  label: 'Doctors'  },
  { href: '/contact',  label: 'Contact'  },
];
const p = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 inset-x-0 z-50 bg-white border-b border-border">
  <div class="w-full px-6 lg:px-10 h-16 grid grid-cols-3 items-center">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 shrink-0" aria-label={clinic.name}>
      <span class="h-12 w-12 shrink-0 overflow-hidden inline-flex items-center justify-center [&>svg]:h-full [&>svg]:w-full [&>svg]:max-h-none" aria-hidden="true" set:html={logoSvg.replace(/width="144"/, 'width="100%"').replace(/height="144"/, 'height="100%"')}/>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-0.5 justify-self-center" aria-label="Primary navigation">
      {navLinks.map(l => (
        <a
          href={l.href}
          class:list={[
            'px-3.5 py-2 rounded-lg text-sm font-body transition-colors duration-150',
            p === l.href
              ? 'text-primary bg-primary-light font-medium'
              : 'text-ink-secondary hover:text-ink hover:bg-surface'
          ]}
          aria-current={p === l.href ? 'page' : undefined}
        >
          {l.label}
        </a>
      ))}
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-2 justify-self-end">
      <a
        href={`tel:${clinic.contact.phone}`}
        class="hidden lg:flex items-center gap-1.5 text-sm text-ink-secondary hover:text-ink transition-colors"
        aria-label="Call us"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        {clinic.contact.phone}
      </a>

      <a
        href={`https://wa.me/${clinic.contact.whatsapp}`}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:flex btn-whatsapp text-xs px-3.5 py-2"
        aria-label="Contact on WhatsApp"
      >
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a6.18 6.18 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.128.558 4.127 1.535 5.857L.057 23.882a.5.5 0 00.612.612l6.055-1.476A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.016-1.375l-.359-.214-3.728.908.936-3.628-.234-.374A9.818 9.818 0 1112 21.818z"/>
        </svg>
        WhatsApp
      </a>

      <!-- Mobile toggle -->
      <button
        id="mobile-btn"
        class="md:hidden p-2 rounded-lg text-ink-secondary hover:bg-surface transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg id="icon-menu" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div
    id="mobile-nav"
    class="md:hidden hidden border-t border-border bg-white"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <div class="max-w-6xl mx-auto px-4 py-3 space-y-0.5">
      {navLinks.map(l => (
        <a
          href={l.href}
          class:list={[
            'flex items-center px-3.5 py-2.5 rounded-lg text-sm font-body transition-colors',
            p === l.href
              ? 'text-primary bg-primary-light font-medium'
              : 'text-ink hover:bg-surface'
          ]}
        >
          {l.label}
        </a>
      ))}
      <div class="pt-2 pb-1 flex flex-col gap-2">
        <a href={`tel:${clinic.contact.phone}`} class="btn-outline btn-lg w-full">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Call Us
        </a>
        <a href={`https://wa.me/${clinic.contact.whatsapp}`} target="_blank" rel="noopener noreferrer" class="btn-whatsapp btn-lg w-full">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a6.18 6.18 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.128.558 4.127 1.535 5.857L.057 23.882a.5.5 0 00.612.612l6.055-1.476A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.016-1.375l-.359-.214-3.728.908.936-3.628-.234-.374A9.818 9.818 0 1112 21.818z"/>
          </svg>
          WhatsApp Us
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn   = document.getElementById('mobile-btn');
  const nav   = document.getElementById('mobile-nav');
  const mIcon = document.getElementById('icon-menu');
  const cIcon = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const open = !nav?.classList.contains('hidden');
    nav?.classList.toggle('hidden');
    mIcon?.classList.toggle('hidden', !open);
    cIcon?.classList.toggle('hidden', open);
    btn?.setAttribute('aria-expanded', String(!open));
  });
</script>
