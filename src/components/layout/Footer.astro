---
import { clinic } from '@/data/clinic';
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
const logoSvg = readFileSync(fileURLToPath(new URL('../../../public/lmc.svg', import.meta.url)), 'utf-8');
---

<footer class="border-t border-border bg-white mt-0">
  <!-- Main -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-4" aria-label={clinic.name}>
          <span class="h-10 w-10 shrink-0 block [&>svg]:h-full [&>svg]:w-auto" aria-hidden="true" set:html={logoSvg}/>
          <span class="font-heading font-semibold text-sm text-ink">
            Legian Medical <span class="text-ink-secondary font-normal">Clinic</span>
          </span>
        </a>
        <p class="text-sm text-ink-secondary leading-relaxed mb-4">
          Professional healthcare in Legian, Bali for tourists, expats, and local residents.
        </p>
        <span class="badge-open">
          <span class="w-1.5 h-1.5 rounded-full bg-accent inline-block"></span>
          Open daily {clinic.hours.opens}–{clinic.hours.closes}
        </span>
      </div>

      <!-- Links -->
      <div>
        <p class="section-label mb-4">Pages</p>
        <ul class="space-y-2.5">
          {[
            { href: '/',         label: 'Home'      },
            { href: '/about',    label: 'About Us'  },
            { href: '/services', label: 'Services'  },
            { href: '/doctors',  label: 'Doctors'   },
            { href: '/contact',  label: 'Contact'   },
          ].map(l => (
            <li>
              <a href={l.href} class="text-sm text-ink-secondary hover:text-primary transition-colors">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <p class="section-label mb-4">Services</p>
        <ul class="space-y-2.5">
          {[
            ['general-practice',  'General Practice'    ],
            ['emergency-care',    'Emergency Care'      ],
            ['iv-drip-therapy',   'IV Drip Therapy'     ],
            ['wound-treatment',   'Wound Treatment'     ],
            ['travel-medicine',   'Travel Medicine'     ],
            ['services',          'View All →'          ],
          ].map(([slug, label]) => (
            <li>
              <a
                href={slug === 'services' ? '/services' : `/services/${slug}`}
                class="text-sm text-ink-secondary hover:text-primary transition-colors"
              >{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="section-label mb-4">Contact</p>
        <address class="not-italic space-y-3">
          <div class="flex gap-2.5 items-start">
            <svg class="w-4 h-4 text-primary mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <p class="text-sm text-ink-secondary leading-relaxed">{clinic.address.full}</p>
          </div>
          <div class="flex gap-2.5 items-center">
            <svg class="w-4 h-4 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href={`tel:${clinic.contact.phone}`} class="text-sm text-ink-secondary hover:text-primary transition-colors">
              {clinic.contact.phone}
            </a>
          </div>
          <div class="flex gap-2.5 items-center">
            <svg class="w-4 h-4 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href={`mailto:${clinic.contact.email}`} class="text-sm text-ink-secondary hover:text-primary transition-colors">
              {clinic.contact.email}
            </a>
          </div>
        </address>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-xs text-ink-secondary/60">&copy; {new Date().getFullYear()} {clinic.name}. All rights reserved.</p>
      <p class="text-xs text-ink-secondary/60">{clinic.address.locality}, {clinic.address.region}, Indonesia</p>
    </div>
  </div>
</footer>
